# Notifications email (désactivé par défaut)
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_FROM=no-reply@supra-banking.local

# SMTP
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# Plafonds virements
MAX_TRANSFER_SINGLE_AMOUNT=10000
MAX_TRANSFER_DAILY_TOTAL=15000
